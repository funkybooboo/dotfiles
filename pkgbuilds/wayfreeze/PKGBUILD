# Maintainer: nate (local build from upstream release tag, off-AUR)
pkgname=wayfreeze
pkgver=0.2.0
pkgrel=1
pkgdesc='A Wayland screen freezing tool'
arch=('x86_64')
url='https://github.com/jappie3/wayfreeze'
license=('AGPL-3.0-or-later')
depends=('wayland' 'libxkbcommon')
# cargo is provided by the mise/rustup-managed toolchain (migration 000202),
# NOT by a pacman package. Do NOT list it in makedepends -- `makepkg -s` would
# otherwise try `sudo pacman -S cargo` to satisfy it, which both duplicates the
# rustup install and prompts for sudo mid-migration. The build() runs cargo
# from PATH. (Mirrors the tdf local PKGBUILD's treatment of rustup.)
# Supersedes the former AUR wayfreeze-git (pinned to the 0.2.0 release tag).
replaces=(wayfreeze-git)
conflicts=(wayfreeze-git)
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/$pkgver.tar.gz")
sha256sums=('9ab941cbd242f82a7ff807c573e23f5f0576c2815a8a493581a9037a0d754bb6')

build() {
  cd "$pkgname-$pkgver"
  export CARGO_TARGET_DIR=target
  cargo build --release --frozen
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null \
    || install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING" 2>/dev/null \
    || true
}
