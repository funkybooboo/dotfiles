{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-with-claude"
  ],
  "provider": {
    "opencode-go": {
      "options": {
        "apiKey": "{{ secret:API/OpenCode/api_key }}"
      }
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.env.local": "deny",
      "**/.env.production": "deny",
      "**/.env.development": "deny",
      "**/.env.test": "deny",
      "**/.env.example": "allow",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.cer": "deny",
      "**/*.crt": "deny",
      "**/secrets/**": "deny",
      "**/credentials/**": "deny",
      "**/*credentials*.json": "deny",
      "**/*secret*.json": "deny",
      "**/*secret*.yaml": "deny",
      "**/*secret*.yml": "deny",
      "**/*token*": "deny",
      "**/*bearer*": "deny",
      "**/*password*.txt": "deny",
      "**/*passwd*.txt": "deny",
      "**/.aws/credentials": "deny",
      "**/.aws/config": "deny",
      "**/.kube/config": "deny",
      "**/.ssh/id_*": "deny",
      "**/.ssh/*_rsa*": "deny",
      "**/.ssh/*_dsa*": "deny",
      "**/.ssh/*_ecdsa*": "deny",
      "**/.ssh/*_ed25519*": "deny",
      "**/.gnupg/**": "deny",
      "**/keystore": "deny",
      "**/*.keystore": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/auth.json": "deny",
      "**/.netrc": "deny",
      "**/.git-credentials": "deny",
      "**/master.key": "deny",
      "**/id_rsa": "deny",
      "**/id_dsa": "deny",
      "**/id_ecdsa": "deny",
      "**/id_ed25519": "deny",
      "**/firebase-adminsdk-*.json": "deny",
      "**/gcloud-service-key.json": "deny",
      "**/client_secret*.json": "deny",
      "**/database.yml": "deny"
    },
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "ask",
    "websearch": "allow",
    "codesearch": "allow",
    "edit": {
      "*": "ask",
      "**/*.md": "allow",
      "**/*.mdx": "allow",
      "**/README*": "allow",
      "**/CHANGELOG*": "allow",
      "**/CONTRIBUTING*": "allow",
      "**/LICENSE*": "allow",
      "**/test.py": "allow",
      "**/test_*.py": "allow",
      "**/*_test.py": "allow",
      "/tmp/**": "allow",
      "tmp/**": "allow",
      "**/tmp/**": "allow",
      "**/.git/**": "deny",
      "**/node_modules/**": "deny",
      "**/package-lock.json": "deny",
      "**/yarn.lock": "deny",
      "**/pnpm-lock.yaml": "deny",
      "**/bun.lockb": "deny",
      "**/Cargo.lock": "deny",
      "**/Gemfile.lock": "deny",
      "**/poetry.lock": "deny",
      "**/composer.lock": "deny",
      "**/Pipfile.lock": "deny"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git ls-files*": "allow",
      "npm list*": "allow",
      "npm outdated*": "allow",
      "npm view*": "allow",
      "yarn list*": "allow",
      "pnpm list*": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "bun test*": "allow",
      "cargo test*": "allow",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "go test*": "allow",
      "npm run build": "allow",
      "cargo build*": "allow",
      "cargo clippy*": "allow",
      "tsc --noEmit*": "allow",
      "go build*": "allow",
      "biome check*": "allow",
      "biome ci*": "allow",
      "ruff check*": "allow",
      "eslint*": "allow",
      "npx biome*": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "docker ps*": "allow",
      "docker images*": "allow",
      "docker inspect*": "allow",
      "kubectl get*": "allow",
      "kubectl describe*": "allow",
      "which *": "allow",
      "whereis *": "allow",
      "env": "allow",
      "printenv*": "allow",
      "echo *": "allow",
      "date": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "touch /tmp/*": "allow",
      "touch tmp/*": "allow",
      "rm *": "ask",
      "rm -rf*": "ask",
      "dd *": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "parted*": "deny",
      "> /dev/*": "deny",
      "chmod 777*": "deny",
      "chown root*": "deny"
    },
    "task": {
      "*": "ask",
      "explore": "allow"
    },
    "lsp": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "external_directory": {
      "*": "ask",
      "/usr/share/doc/**": "allow",
      "/usr/share/man/**": "allow",
      "/tmp/**": "allow",
      "/var/tmp/**": "deny"
    },
    "doom_loop": "ask"
  },
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": [
        "mgrep",
        "mcp"
      ],
      "enabled": true
    }
  }
}