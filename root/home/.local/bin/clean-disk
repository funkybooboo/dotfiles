#!/usr/bin/env bash
#
# clean-disk — clean system caches on Arch Linux
#
# Cleans: pacman cache, flatpak runtimes, podman images, systemd journal,
# /tmp, nix store garbage, mise caches, trash. Launches ncdu at the end.
#
set -euo pipefail

TS() { date '+%F %T'; }
echo "[$(TS)] === Starting system cleanup ==="
echo ""

# --- Detect distro ---
DISTRO=""
if [ -f /etc/os-release ]; then
    . /etc/os-release
    case "$ID" in
        arch|manjaro|endeavouros)
            DISTRO="Arch Linux"
            ;;
    esac
fi

if [ -z "$DISTRO" ]; then
    echo "[$(TS)] ERROR: Unsupported distribution. This script only supports Arch Linux."
    exit 1
fi

echo "[$(TS)] Detected distro: $DISTRO"
echo ""

# 1) Flatpak cleanup
if command -v flatpak >/dev/null 2>&1; then
    echo "[$(TS)] Removing unused Flatpak runtimes and apps..."
    sudo flatpak uninstall --unused -y
    echo "-> Unused Flatpak content removed."
fi
echo ""

# 2) Vacuum systemd journal logs older than 7 days
echo "[$(TS)] Vacuuming journal logs older than 7 days..."
sudo journalctl --vacuum-time=7d || echo "Failed to vacuum journal logs."
echo "-> Old journal entries purged."
echo ""

# 3) Podman cleanup
if command -v podman >/dev/null 2>&1; then
    echo "[$(TS)] Pruning unused Podman objects..."
    podman system prune -a --volumes --force 2>/dev/null || true
    podman builder prune --all --force 2>/dev/null || true
    echo "-> Podman cleanup finished."
fi
echo ""

# 4) /tmp cleanup
echo "[$(TS)] Deleting /tmp files older than 7 days..."
sudo find /tmp -mindepth 1 -mtime +7 -print -exec sudo rm -rf {} \; || echo "Failed to clean /tmp directory."
echo "-> /tmp cleaned."
echo ""

# 5) Arch package cache cleanup
echo "[$(TS)] Cleaning pacman package cache..."
sudo pacman -Sc --noconfirm
echo "-> Package cache cleaned."
echo ""

# 6) nix store garbage collection
if command -v nix >/dev/null 2>&1; then
    echo "[$(TS)] Garbage collecting nix store..."
    nix store gc 2>/dev/null || true
    echo "-> Nix store GC finished."
fi
echo ""

# 7) mise cache cleanup (per-project tool caches, not runtimes)
if command -v mise >/dev/null 2>&1; then
    echo "[$(TS)] Cleaning mise cache..."
    mise cache clear 2>/dev/null || true
    echo "-> mise cache cleaned."
fi
echo ""

# 8) Trash
echo "[$(TS)] Emptying trash..."
rm -rf ~/.local/share/Trash/files/* ~/.local/share/Trash/info/* 2>/dev/null || true
echo "-> Trash emptied."

echo "[$(TS)] === System cleanup complete! ==="

# Launch ncdu for disk usage analysis
echo "[$(TS)] Launching ncdu for disk usage analysis..."
if command -v ncdu >/dev/null 2>&1; then
    sudo ncdu / || echo "Failed to run ncdu."
else
    echo "ncdu is not installed. Please install it to analyze disk usage."
fi
