#!/usr/bin/env bash
# update — converge the system + roll forward installed tools to latest.
#
# Thin shim over migrate.sh. Re-running migrate.sh keeps the whole system
# current:
#   000001   pacman -Syu (system upgrade)
#   000011   nix package manager (install + config)
#   000301   flatpak update
#   000551   Proton Drive CLI (install-pinned-else-roll-to-upstream-latest)
#   000600   runtime roll-forward: mise upgrade, nix flake update +
#            nix profile upgrade --all, pi update, tldr --update
# The flake.lock bump from 000600 shows as an uncommitted change — commit it
# to pin the new nixpkgs revision across machines.
#
# Firmware updates (reboot-gated, potentially disruptive) stay a separate
# manual command: `update-firmware`.

set -euo pipefail

# Short-circuit help/version probes so a stray `update --help` doesn't kick
# off a full system convergence run.
for _a in "$@"; do
  case "$_a" in
    -h|--help|help)
      sed -n '2,16p' "$0"; exit 0 ;;
  esac
done

exec "$HOME/dotfiles/migrate.sh" "$@"
