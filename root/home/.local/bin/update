#!/usr/bin/env bash
# update — converge the system + roll forward installed tools to latest.
#
# This is now a thin shim over migrate.sh. The rolling-forward logic that used
# to live here (flatpak update, rustup, cargo, go, mise, npm, uv, pipx, gem,
# pnpm, bun, pi, composer, ghcup/stack/cabal, tldr, GitHub fork sync,
# ~/sources rebuild, Docker/Podman image pulls, Proton Drive manifest) has been
# folded into idempotent migrations:
#   000001   system upgrade (now `yay -Syu` -- covers pacman + AUR)
#   000301   flatpak update
#   000551   Proton Drive CLI install-pinned-else-roll-to-upstream-latest
#   000600   runtime roll-forward (everything else)
# Re-running `./migrate.sh` now keeps the whole system current; this shim exists
# so the existing `update` muscle memory still does the right thing.
#
# Firmware updates (reboot-gated, potentially disruptive) stay a separate
# manual command: `update-firmware`.

set -euo pipefail

# Short-circuit help/version probes so a stray `update --help` doesn't kick
# off a full system convergence run.
for _a in "$@"; do
  case "$_a" in
    -h|--help|help)
      sed -n '2,18p' "$0"; exit 0 ;;
  esac
done

exec "$HOME/dotfiles/migrate.sh" "$@"