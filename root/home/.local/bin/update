#!/usr/bin/env bash
# System update script for Arch Linux

set -euo pipefail

echo "=== System Update (Arch Linux) ==="
echo ""

# Step 1: Refresh Pacman mirrors and update Arch packages
if command -v reflector >/dev/null 2>&1; then
    echo "→ Refreshing Pacman mirrorlist..."
    sudo reflector --latest 20 --sort rate --save /etc/pacman.d/mirrorlist 2>/dev/null || true
    echo ""
fi
if command -v yay >/dev/null 2>&1; then
    echo "→ Updating Arch/AUR packages (yay)..."
    yay -Syu --noconfirm
    echo ""
else
    echo "→ yay not found, using pacman..."
    sudo pacman -Syu --noconfirm
    echo ""
fi
sudo systemctl daemon-reload 2>/dev/null || true

# Step 2: Update Flatpak applications
if command -v flatpak >/dev/null 2>&1; then
    echo "→ Updating Flatpak applications..."
    flatpak update -y
    echo ""
fi

# Step 3: Update firmware (delegate to dedicated update-firmware script)
if command -v update-firmware >/dev/null 2>&1; then
    echo "→ Running firmware update..."
    update-firmware
    echo ""
elif command -v fwupdmgr >/dev/null 2>&1; then
    echo "→ Checking for firmware updates..."
    fwupdmgr refresh || true
    fwupdmgr update || echo "No firmware updates available"
    echo ""
fi

# Step 4: Update Rust toolchain and packages
if command -v rustup >/dev/null 2>&1; then
    echo "→ Updating Rust toolchain..."
    rustup update 2>/dev/null || true
    echo ""
fi
if command -v cargo >/dev/null 2>&1; then
    echo "→ Updating Rust packages..."
    cargo install cargo-update 2>/dev/null || true
    cargo install-update -a 2>/dev/null || echo "warning: cargo package update failed"
    echo ""
fi

# Step 5: Update Go packages (extract module paths via go version -m)
if command -v go >/dev/null 2>&1 && compgen -G "$HOME/go/bin/*" >/dev/null 2>&1; then
    echo "→ Updating Go packages..."
    for bin in "$HOME/go/bin/"*; do
        [ -f "$bin" ] || continue
        mod_path=$(go version -m "$bin" 2>/dev/null | awk '/^\s+path/ {print $2}')
        if [[ -n "$mod_path" ]]; then
            echo "  → Updating $mod_path..."
            go install "${mod_path}@latest" 2>/dev/null || echo "    warning: could not update $mod_path"
        fi
    done
    echo ""
fi

# Step 6: Update mise-managed tools (mise itself is updated by pacman in Step 1)
if command -v mise >/dev/null 2>&1; then
    echo "→ Upgrading mise-managed tools..."
    mise upgrade --yes 2>/dev/null || true
    echo ""
fi

# Step 7: Update npm global packages
if command -v npm >/dev/null 2>&1; then
    echo "→ Updating npm global packages..."
    npm update -g 2>/dev/null || true
    echo ""
fi

# Step 8: Update uv (Python package manager) and uv-managed tools
if command -v uv >/dev/null 2>&1; then
    echo "→ Updating uv..."
    uv self update 2>/dev/null || true
    echo "  → Upgrading uv-managed tools..."
    uv tool upgrade --all 2>/dev/null || true
    echo ""
fi

# Step 9: Update ghcup and Haskell (the ghcup binary itself) and Stack
if command -v ghcup >/dev/null 2>&1; then
    echo "→ Updating ghcup..."
    ghcup upgrade 2>/dev/null || true
    echo ""
fi
if command -v stack >/dev/null 2>&1; then
    echo "→ Upgrading Stack..."
    stack upgrade 2>/dev/null || true
    echo ""
fi
if command -v cabal >/dev/null 2>&1; then
    echo "→ Refreshing Hackage package index (cabal)..."
    cabal update 2>/dev/null || true
    echo ""
fi

# Step 10: Update pipx global tools
if command -v pipx >/dev/null 2>&1; then
    echo "→ Upgrading pipx-installed tools..."
    pipx upgrade-all 2>/dev/null || true
    echo ""
fi

# Step 11: Update Ruby gems
if command -v gem >/dev/null 2>&1; then
    echo "→ Updating Ruby gems..."
    gem update --user-install 2>/dev/null || true
    echo ""
fi

# Step 12: Update pip (system Python packages)
if command -v pip >/dev/null 2>&1; then
    echo "→ Updating pip..."
    pip install --user --upgrade pip 2>/dev/null || true
    echo ""
fi

# Step 13: Update pnpm global packages
if command -v pnpm >/dev/null 2>&1; then
    echo "→ Updating pnpm global packages..."
    pnpm add -g pnpm 2>/dev/null || true
    echo ""
fi

# Step 14: Update bun
if command -v bun >/dev/null 2>&1; then
    echo "→ Updating bun..."
    bun upgrade 2>/dev/null || true
    echo ""
fi

# Step 15: Update Pi coding agent
if command -v pi >/dev/null 2>&1; then
    echo "→ Updating Pi coding agent..."
    pi update 2>/dev/null || true
    echo ""
fi

# Step 16: Update Composer (PHP)
if command -v composer >/dev/null 2>&1; then
    echo "→ Updating Composer..."
    composer self-update 2>/dev/null || true
    echo "  → Updating Composer global packages..."
    composer global update 2>/dev/null || true
    echo ""
fi

# Step 17: Update tldr cache
if command -v tldr >/dev/null 2>&1; then
    echo "→ Updating tldr cache..."
    tldr --update 2>/dev/null || true
    echo ""
fi

# Step 18: Sync GitHub forks with upstream
if command -v gh >/dev/null 2>&1; then
    echo "→ Syncing GitHub forks with upstream..."
    for repo in $(gh repo list --fork --limit 50 --json nameWithOwner --jq '.[].nameWithOwner'); do
        echo "  → Syncing $repo..."
        if gh repo sync "$repo" 2>/dev/null; then
            echo "    synced"
        else
            echo "    warning: could not sync $repo"
        fi
    done
    echo ""
fi

# Step 19: Update git repos in ~/sources
if [[ -d "$HOME/sources" ]]; then
    echo "→ Updating git repos in ~/sources..."
    for repo in "$HOME/sources"/*/; do
        [[ -d "$repo/.git" ]] || continue
        repo_name=$(basename "$repo")
        if git -C "$repo" pull --ff-only 2>/dev/null; then
            echo "  ✓ $repo_name"
        else
            echo "  ✗ $repo_name (diverged or error)"
        fi
    done
    echo ""
fi

# Step 20: Rebuild ~/sources repos (auto-detected build systems)
_build_repo() {
    local repo="$1"
    local name
    name=$(basename "$repo")

    # CMake with existing Ninja build dir
    local ninja_dir=""
    for d in "$repo"/Build/release "$repo"/build "$repo"/Build; do
        if [[ -f "$d/build.ninja" ]]; then ninja_dir="$d"; break; fi
    done
    if [[ -n "$ninja_dir" ]]; then
        echo "  → $name (ninja)"
        if ninja -C "$ninja_dir" 2>/dev/null; then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # CMake with existing Makefile build dir
    local cmake_make_dir=""
    for d in "$repo"/Build/release "$repo"/build "$repo"/Build; do
        if [[ -f "$d/Makefile" ]] && [[ -f "$repo/CMakeLists.txt" ]]; then cmake_make_dir="$d"; break; fi
    done
    if [[ -n "$cmake_make_dir" ]]; then
        echo "  → $name (cmake+make)"
        if make -C "$cmake_make_dir" 2>/dev/null; then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Autoconf/HandBrake-style configure harness: a ./configure at the repo
    # root (no CMakeLists.txt) generates build/Makefile, driven via
    # `make --directory=build` + `sudo make --directory=build install`. If the
    # build dir was removed (or configure changed after a git pull), re-run
    # ./configure to bootstrap it first. Matches HandBrake (migration 000552).
    if [[ -f "$repo/configure" ]] && [[ ! -f "$repo/CMakeLists.txt" ]]; then
        if [[ ! -f "$repo/build/Makefile" ]]; then
            echo "  → $name (configure: bootstrapping build/Makefile)"
            ( cd "$repo" && ./configure --launch-jobs="$(nproc)" --launch ) >/dev/null 2>&1 || true
        fi
        if [[ -f "$repo/build/Makefile" ]]; then
            echo "  → $name (make -C build)"
            # WARNING: sudo make install runs arbitrary install targets from
            # source repos
            if make -C "$repo/build" 2>/dev/null && sudo make -C "$repo/build" install 2>/dev/null; then
                echo "    ✓ $name"; return 0
            else
                echo "    ✗ $name failed"; return 1
            fi
        fi
    fi

    # Go module
    if [[ -f "$repo/go.mod" ]]; then
        echo "  → $name (go install)"
        if (cd "$repo" && go install ./... 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Cargo (Rust)
    if [[ -f "$repo/Cargo.toml" ]]; then
        echo "  → $name (cargo build)"
        if (cd "$repo" && cargo build --release 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Meson
    if [[ -f "$repo/meson.build" ]]; then
        local builddir="$repo/builddir"
        if [[ -f "$builddir/build.ninja" ]]; then
            echo "  → $name (meson+ninja)"
            if ninja -C "$builddir" 2>/dev/null; then
                echo "    ✓ $name"; return 0
            else
                echo "    ✗ $name failed"; return 1
            fi
        fi
    fi

    # Makefile (standalone, not cmake-generated; handles both Makefile and makefile)
    if [[ -f "$repo/Makefile" || -f "$repo/makefile" ]] && [[ ! -f "$repo/CMakeLists.txt" ]]; then
        echo "  → $name (make)"
        # WARNING: sudo make install runs arbitrary install targets from source repos
        if make -C "$repo" 2>/dev/null && sudo make -C "$repo" install 2>/dev/null; then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Gemfile (Ruby deps only)
    if [[ -f "$repo/Gemfile" ]]; then
        echo "  → $name (bundle install)"
        if (cd "$repo" && bundle install 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # package.json (Node deps + build)
    if [[ -f "$repo/package.json" ]]; then
        echo "  → $name (npm)"
        if (cd "$repo" && npm install 2>/dev/null && npm run build 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    return 2
}

if [[ -d "$HOME/sources" ]]; then
    echo "→ Rebuilding ~/sources repos..."
    for repo in "$HOME/sources"/*/; do
        [[ -d "$repo/.git" ]] || continue
        _rc=0
        _build_repo "$repo" || _rc=$?
        if [[ $_rc -eq 2 ]]; then
            echo "  ⊘ $(basename "$repo") (no recognized build system)"
        fi
    done
    echo ""
fi

# Step 21: Update Docker container images
if command -v docker >/dev/null 2>&1; then
    echo "→ Updating Docker container images..."
    if sudo docker ps -q >/dev/null 2>&1; then
        for container in $(sudo docker ps --format '{{.Names}}'); do
            image=$(sudo docker inspect --format='{{.Config.Image}}' "$container" 2>/dev/null || true)
            if [[ -n "$image" ]]; then
                echo "  → Pulling $image for $container..."
                sudo docker pull "$image" 2>/dev/null || echo "    warning: could not pull $image"
            fi
        done
    fi
    echo ""
fi

# Step 22: Update Podman container images
if command -v podman >/dev/null 2>&1; then
    echo "→ Updating Podman container images..."
    if podman ps -q >/dev/null 2>&1; then
        for container in $(podman ps --format '{{.Names}}'); do
            image=$(podman inspect --format='{{.Config.Image}}' "$container" 2>/dev/null || true)
            if [[ -n "$image" ]]; then
                echo "  → Pulling $image for $container..."
                podman pull "$image" 2>/dev/null || echo "    warning: could not pull $image"
            fi
        done
    fi
    echo ""
fi

# Step 23: Update Proton Drive CLI (scrape Proton's release manifest for
# the current version + platform URL + published SHA-512)
#
# Proton Drive has no package-manager distribution (no Arch/AUR/Flatpak, no
# GitHub releases) -- the only channel is a per-release prebuilt ELF at a
# versioned path. There is no "latest" redirect. Proton DOES publish a stable
# manifest at https://proton.me/download/drive/cli/index.html whose <title>
# holds the version and whose table lists per-platform URLs with SHA-512
# checksums. We parse the linux/x64 row, compare to the installed version, and
# if newer (or absent) download and verify the binary against the upstream-
# published SHA-512 before installing. Non-fatal on any failure.
#
# The migration (000551) installs a pinned 0.4.6 as the initial, reproducible
# install; this step rolls forward to whatever Proton currently publishes.
if command -v proton-drive >/dev/null 2>&1 || [[ -d "$HOME/.local/bin" ]]; then
    echo "→ Checking Proton Drive CLI..."
    pd_manifest_url="https://proton.me/download/drive/cli/index.html"
    pd_tmp="$(mktemp -d)"
    if curl -fsSL --connect-timeout 15 "$pd_manifest_url" -o "$pd_tmp/index.html" 2>/dev/null; then
        # URL is unique to the linux-x64 row (no other platform contains "linux-x64").
        pd_url="$(grep -oE 'https://proton\.me/download/drive/cli/[0-9]+\.[0-9]+\.[0-9]+/linux-x64/proton-drive' "$pd_tmp/index.html" | head -1)"
        # The SHA-512 is the next 128-hex <code> blob AFTER the linux-x64 URL line.
        pd_sha512=""
        if [[ -n "$pd_url" ]]; then
            pd_url_line="$(grep -n 'linux-x64/proton-drive"' "$pd_tmp/index.html" | head -1 | cut -d: -f1)"
            [[ -n "$pd_url_line" ]] && pd_sha512="$(awk "NR>$pd_url_line" "$pd_tmp/index.html" | grep -oE '[0-9a-f]{128}' | head -1)"
        fi
        pd_version="${pd_url##*/cli/}"; pd_version="${pd_version%%/*}"
        if [[ -z "$pd_url" || -z "$pd_sha512" || -z "$pd_version" ]]; then
            echo "  warning: could not parse Proton Drive CLI manifest (page format changed?)"
        else
            pd_installed=""
            if command -v proton-drive >/dev/null 2>&1; then
                # e.g. "Proton Drive CLI cli-drive@0.4.6+21156f23" -> 0.4.6
                pd_installed="$(proton-drive --version 2>/dev/null | head -1)"
                pd_installed="${pd_installed#*@}"; pd_installed="${pd_installed%%+*}"
            fi
            if [[ "$pd_installed" == "$pd_version" ]]; then
                echo "  ✓ proton-drive $pd_version (up to date)"
            else
                echo "  → proton-drive ${pd_installed:-<absent>} -> $pd_version"
                if curl -fL --connect-timeout 30 -o "$pd_tmp/proton-drive" "$pd_url" 2>/dev/null; then
                    pd_actual="$(sha512sum "$pd_tmp/proton-drive" | awk '{print $1}')"
                    if [[ "$pd_actual" != "$pd_sha512" ]]; then
                        echo "  warning: sha512 mismatch (not installing)"
                    elif install -m755 "$pd_tmp/proton-drive" "$HOME/.local/bin/proton-drive" 2>/dev/null; then
                        echo "  ✓ proton-drive updated to $pd_version"
                    else
                        echo "  warning: failed to install proton-drive binary"
                    fi
                else
                    echo "  warning: download failed for $pd_url"
                fi
            fi
        fi
    else
        echo "  warning: could not fetch Proton Drive CLI manifest"
    fi
    rm -rf "$pd_tmp"
    echo ""
fi

# Step 24: Refresh shell caches
rm -f ~/.cache/fzf_fish_init.fish

echo "=== Update Complete ==="
