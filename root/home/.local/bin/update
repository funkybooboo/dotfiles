#!/usr/bin/env bash
# System update script for Arch Linux with Omarchy

set -euo pipefail

# Resolve dotfiles directory once for use throughout script
_SCRIPT_REAL="$(readlink -f "${BASH_SOURCE[0]}")"
_DOTFILES_DIR="$(cd "$(dirname "$_SCRIPT_REAL")/../../../.." && pwd)"

echo "=== System Update (Arch Linux) ==="
echo ""

# Step 1: Update Arch packages with yay (AUR helper)
if command -v yay >/dev/null 2>&1; then
    echo "→ Updating Arch/AUR packages (yay)..."
    yay -Syu --noconfirm
    echo ""
else
    echo "→ yay not found, using pacman..."
    sudo pacman -Syu --noconfirm
    echo ""
fi

# Step 2: Update Flatpak applications
if command -v flatpak >/dev/null 2>&1; then
    echo "→ Updating Flatpak applications..."
    flatpak update -y
    echo ""
fi

# Step 2.5: Update dotfiles git submodules from remote
if [[ -f "$_DOTFILES_DIR/.gitmodules" ]]; then
    echo "→ Updating dotfiles git submodules..."
    if git -C "$_DOTFILES_DIR" submodule update --init --remote --recursive; then
        # Ensure each submodule is on its tracked branch (not detached HEAD)
        git -C "$_DOTFILES_DIR" config --file .gitmodules --get-regexp path | awk '{print $2}' | while read -r submod_path; do
            submod_branch=$(git -C "$_DOTFILES_DIR" config --file .gitmodules --get "submodule.$submod_path.branch" 2>/dev/null || echo "")
            if [[ -n "$submod_branch" ]]; then
                git -C "$_DOTFILES_DIR/$submod_path" checkout "$submod_branch" 2>/dev/null || true
            fi
        done
        # Check if submodule pointers changed (only check .gitmodules and submodule paths)
        if ! git -C "$_DOTFILES_DIR" diff --quiet HEAD -- .gitmodules $(git -C "$_DOTFILES_DIR" config --file .gitmodules --get-regexp path | awk '{print $2}') 2>/dev/null; then
            # Only add .gitmodules and submodule paths, not all changes
            git -C "$_DOTFILES_DIR" add .gitmodules
            git -C "$_DOTFILES_DIR" config --file .gitmodules --get-regexp path | awk '{print $2}' | xargs -I {} git -C "$_DOTFILES_DIR" add {}
            git -C "$_DOTFILES_DIR" commit -m "chore: update git submodules from remote"
            echo "  dotfiles submodules updated and committed"
        else
            echo "  dotfiles submodules already up to date"
        fi
    else
        echo "  warning: could not update submodules"
    fi
    echo ""
fi

# Step 3: Update Omarchy
if command -v omarchy-update >/dev/null 2>&1; then
    echo "→ Updating Omarchy..."
    omarchy-update
    echo ""
fi

# Step 3b: Sync omarchy submodule pin after omarchy-update
# The omarchy-update command may have pulled changes to the local checkout.
# Ensure the dotfiles submodule pointer reflects the current local commit.
if [[ -f "$_DOTFILES_DIR/.gitmodules" ]] && grep -q "omarchy" "$_DOTFILES_DIR/.gitmodules" 2>/dev/null; then
    _OMARCHY_SUBMOD="root/home/.local/share/omarchy"
    echo "→ Syncing omarchy submodule pin in dotfiles..."
    # Check if the submodule working tree differs from the recorded commit
    if ! git -C "$_DOTFILES_DIR" diff --quiet HEAD -- "$_OMARCHY_SUBMOD" 2>/dev/null; then
        git -C "$_DOTFILES_DIR" add "$_OMARCHY_SUBMOD"
        git -C "$_DOTFILES_DIR" commit -m "chore: sync omarchy submodule pin after omarchy-update"
        echo "  omarchy submodule pin synced and committed"
    else
        echo "  omarchy submodule pin already in sync"
    fi
    echo ""
fi

# Step 4: Update firmware
if command -v fwupdmgr >/dev/null 2>&1; then
    echo "→ Checking for firmware updates..."
    fwupdmgr refresh || true
    fwupdmgr update || echo "No firmware updates available"
    echo ""
fi

# Step 5: Update Rust packages
if command -v cargo >/dev/null 2>&1; then
    echo "→ Updating Rust packages..."
    cargo install cargo-update 2>/dev/null || true
    cargo install-update -a || echo "cargo-update not installed"
    echo ""
fi

# Step 6: Update Go packages (extract module paths via go version -m)
if command -v go >/dev/null 2>&1 && compgen -G "$HOME/go/bin/*" >/dev/null 2>&1; then
    echo "→ Updating Go packages..."
    for bin in "$HOME/go/bin/"*; do
        [ -f "$bin" ] || continue
        mod_path=$(go version -m "$bin" 2>/dev/null | awk '/^\s+path/ {print $2}')
        if [[ -n "$mod_path" ]]; then
            echo "  → Updating $mod_path..."
            go install "${mod_path}@latest" 2>/dev/null || echo "    warning: could not update $mod_path"
        fi
    done
    echo ""
fi

# Step 7: Update mise-managed tools (mise itself is updated by pacman in Step 1)
if command -v mise >/dev/null 2>&1; then
    echo "→ Upgrading mise-managed tools..."
    mise upgrade --yes 2>/dev/null || true
    echo ""
fi

# Step 8: Update npm global packages
if command -v npm >/dev/null 2>&1; then
    echo "→ Updating npm global packages..."
    npm update -g 2>/dev/null || true
    echo ""
fi

# Step 9: Update uv (Python package manager) and uv-managed tools
if command -v uv >/dev/null 2>&1; then
    echo "→ Updating uv..."
    uv self update 2>/dev/null || true
    echo "  → Upgrading uv-managed tools..."
    uv tool upgrade --all 2>/dev/null || true
    echo ""
fi

# Step 10: Update ghcup (the ghcup binary itself) and Stack
if command -v ghcup >/dev/null 2>&1; then
    echo "→ Updating ghcup..."
    ghcup upgrade 2>/dev/null || true
    echo ""
fi
if command -v stack >/dev/null 2>&1; then
    echo "→ Upgrading Stack..."
    stack upgrade 2>/dev/null || true
    echo ""
fi
if command -v cabal >/dev/null 2>&1; then
    echo "→ Refreshing Hackage package index (cabal)..."
    cabal update 2>/dev/null || true
    echo ""
fi

# Step 12: Update tldr cache
if command -v tldr >/dev/null 2>&1; then
    echo "→ Updating tldr cache..."
    tldr --update 2>/dev/null || true
    echo ""
fi

# Step 12.5: Sync GitHub forks with upstream
if command -v gh >/dev/null 2>&1; then
    echo "→ Syncing GitHub forks with upstream..."
    for repo in $(gh repo list --fork --limit 50 --json nameWithOwner --jq '.[].nameWithOwner'); do
        echo "  → Syncing $repo..."
        if gh repo sync "$repo" 2>/dev/null; then
            echo "    synced"
        else
            echo "    warning: could not sync $repo"
        fi
    done
    echo ""
fi

# Step 12.75: Update git repos in ~/sources
if [[ -d "$HOME/sources" ]]; then
    echo "→ Updating git repos in ~/sources..."
    for repo in "$HOME/sources"/*/; do
        [[ -d "$repo/.git" ]] || continue
        repo_name=$(basename "$repo")
        if git -C "$repo" pull --ff-only 2>/dev/null; then
            echo "  ✓ $repo_name"
        else
            echo "  ✗ $repo_name (diverged or error)"
        fi
    done
    echo ""
fi

# Step 12.875: Rebuild ~/sources repos (auto-detected build systems)
_build_repo() {
    local repo="$1"
    local name
    name=$(basename "$repo")

    # CMake with existing Ninja build dir
    local ninja_dir=""
    for d in "$repo"/Build/release "$repo"/build "$repo"/Build; do
        if [[ -f "$d/build.ninja" ]]; then ninja_dir="$d"; break; fi
    done
    if [[ -n "$ninja_dir" ]]; then
        echo "  → $name (ninja)"
        if ninja -C "$ninja_dir" 2>/dev/null; then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # CMake with existing Makefile build dir
    local cmake_make_dir=""
    for d in "$repo"/Build/release "$repo"/build "$repo"/Build; do
        if [[ -f "$d/Makefile" ]] && [[ -f "$repo/CMakeLists.txt" ]]; then cmake_make_dir="$d"; break; fi
    done
    if [[ -n "$cmake_make_dir" ]]; then
        echo "  → $name (cmake+make)"
        if make -C "$cmake_make_dir" 2>/dev/null; then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Go module
    if [[ -f "$repo/go.mod" ]]; then
        echo "  → $name (go install)"
        if (cd "$repo" && go install . 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Cargo (Rust)
    if [[ -f "$repo/Cargo.toml" ]]; then
        echo "  → $name (cargo build)"
        if (cd "$repo" && cargo build --release 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Meson
    if [[ -f "$repo/meson.build" ]]; then
        local builddir="$repo/builddir"
        if [[ -f "$builddir/build.ninja" ]]; then
            echo "  → $name (meson+ninja)"
            if ninja -C "$builddir" 2>/dev/null; then
                echo "    ✓ $name"; return 0
            else
                echo "    ✗ $name failed"; return 1
            fi
        fi
    fi

    # Makefile (standalone, not cmake-generated)
    if [[ -f "$repo/Makefile" ]] && [[ ! -f "$repo/CMakeLists.txt" ]]; then
        echo "  → $name (make)"
        if make -C "$repo" 2>/dev/null && sudo make -C "$repo" install 2>/dev/null; then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # Gemfile (Ruby deps only)
    if [[ -f "$repo/Gemfile" ]]; then
        echo "  → $name (bundle install)"
        if (cd "$repo" && bundle install 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    # package.json (Node deps + build)
    if [[ -f "$repo/package.json" ]]; then
        echo "  → $name (npm)"
        if (cd "$repo" && npm install 2>/dev/null && npm run build 2>/dev/null); then
            echo "    ✓ $name"; return 0
        else
            echo "    ✗ $name failed"; return 1
        fi
    fi

    return 2
}

if [[ -d "$HOME/sources" ]]; then
    echo "→ Rebuilding ~/sources repos..."
    for repo in "$HOME/sources"/*/; do
        [[ -d "$repo/.git" ]] || continue
        _build_repo "$repo"
        ((_rc=$?))
        if [[ $_rc -eq 2 ]]; then
            echo "  ⊘ $(basename "$repo") (no recognized build system)"
        fi
    done
    echo ""
fi

# Step 13: Clean package cache
if command -v yay >/dev/null 2>&1; then
    echo "→ Cleaning package cache..."
    yay -Sc --noconfirm
    echo ""
fi

# Step 14: Refresh shell caches
rm -f ~/.cache/fzf_fish_init.fish

echo "=== Update Complete ==="
