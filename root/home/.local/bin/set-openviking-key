#!/bin/bash
# Set the Gemini API key for OpenViking.
# Uses OPENVIKING_API_KEY env var — never writes the key to disk.
set -euo pipefail

KEY="${1:-}"
if [[ -z "$KEY" ]]; then
  echo "Usage: set-openviking-key \"your-gemini-api-key\""
  echo ""
  echo "This writes the API key to ~/.openviking/ov.conf."
  echo "Alternatively, set OPENVIKING_API_KEY environment variable instead."
  exit 1
fi

CONF="$HOME/.openviking/ov.conf"
if [[ ! -f "$CONF" ]]; then
  echo "Error: $CONF not found. Run install.sh first."
  exit 1
fi

python3 -c "
import json, sys
with open('$CONF') as f:
    c = json.load(f)
c['embedding']['dense']['api_key'] = '$KEY'
c['vlm']['api_key'] = '$KEY'
with open('$CONF', 'w') as f:
    json.dump(c, f, indent=2)
    f.write('\n')
"

echo "API key set in $CONF"
if systemctl --user is-active openviking.service &>/dev/null; then
  systemctl --user restart openviking.service
  echo "Service restarted."
else
  echo "Service not running. Start with: systemctl --user start openviking.service"
fi