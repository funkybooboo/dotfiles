#!/bin/bash
current=$(powerprofilesctl get 2>/dev/null || echo "balanced")

choose() {
    echo "Current: $current"
    echo ""
    echo "1) performance"
    echo "2) balanced"
    echo "3) power-saver"
    echo ""
    printf "Select power mode [1-3]: "
    read -r choice
    case $choice in
        1) powerprofilesctl set performance && echo "Set to performance" ;;
        2) powerprofilesctl set balanced && echo "Set to balanced" ;;
        3) powerprofilesctl set power-saver && echo "Set to power-saver" ;;
        *) echo "Cancelled" ;;
    esac
    printf "Press Enter to close..."
    read -r
}

ghostty -e bash -c "$(declare -f choose); choose"