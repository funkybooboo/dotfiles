#!/usr/bin/env bash
# secretmgr - Proton Pass CLI wrapper with stable interface
# Swap BACKEND to switch password managers without changing any scripts.
set -euo pipefail

VERSION="1.0.0"
CONFIG_FILE="${SECRETMGR_CONFIG:-$HOME/.config/secretmgr/config.toml}"
BACKEND="protonpass"
CLIPBOARD_TIMEOUT=45

# ─── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[OK]${NC}  $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error()   { echo -e "${RED}[ERR]${NC} $*" >&2; }
die()         { log_error "$*"; exit 1; }

# ─── Config Parsing ────────────────────────────────────────────────────────────
declare -A VAULT_MAP=()

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        return
    fi
    BACKEND=$(grep -oP '(?<=type\s*=\s*")[^"]+' "$CONFIG_FILE" 2>/dev/null || echo "$BACKEND")
    local in_vaults=false
    while IFS= read -r line; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        if [[ "$line" == "[vaults]" ]]; then
            in_vaults=true
            continue
        fi
        if [[ "$line" == "["* ]]; then
            in_vaults=false
            continue
        fi
        if $in_vaults && [[ "$line" == *=* ]]; then
            local key="${line%%=*}"
            local val="${line#*=}"
            key="${key// /}"
            val="${val//\"/}"
            val="${val//\'/}"
            VAULT_MAP["$key"]="$val"
        fi
    done < "$CONFIG_FILE"
}

resolve_vault() {
    local alias="$1"
    if [[ -n "${VAULT_MAP[$alias]+x}" ]]; then
        echo "${VAULT_MAP[$alias]}"
    else
        echo "$alias"
    fi
}

# ─── Proton Pass Backend ───────────────────────────────────────────────────────
PASS_CLI="pass-cli"

_pp_check() {
    command -v "$PASS_CLI" &>/dev/null || die "pass-cli not installed. Run: secretmgr init"
}

_pp_logged_in() {
    "$PASS_CLI" info &>/dev/null
}

_pp_vault_exists() {
    local vault="$1"
    "$PASS_CLI" vault list --output json 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if any(v['name']=='$vault' for v in d['vaults']) else 1)" 2>/dev/null
}

_pp_item_exists() {
    local vault="$1"
    local item="$2"
    "$PASS_CLI" item list "$vault" --output json 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if any(i['title']=='$item' for i in d['items']) else 1)" 2>/dev/null
}

_pp_get_field() {
    local vault="$1"
    local item="$2"
    local field="$3"
    local result
    result=$("$PASS_CLI" item view --vault-name "$vault" --item-title "$item" --field "$field" 2>/dev/null) || return 1
    echo "$result"
}

_pp_create_item() {
    local vault="$1"
    local item="$2"
    shift 2
    local all_args=("$@")
    # Classify fields: login-only or has custom fields
    local login_args=("--vault-name" "$vault" "--title" "$item")
    local has_custom=false
    for kv in "${all_args[@]}"; do
        local key="${kv%%=*}"
        case "$key" in
            username|password|email|url) ;;
            *) has_custom=true; break ;;
        esac
    done
    if ! $has_custom; then
        # Simple login item — no custom fields
        for kv in "${all_args[@]}"; do
            local key="${kv%%=*}"
            local val="${kv#*=}"
            case "$key" in
                username)   login_args+=("--username" "$val") ;;
                password)   login_args+=("--password" "$val") ;;
                email)      login_args+=("--email" "$val") ;;
                url)        login_args+=("--url" "$val") ;;
            esac
        done
        "$PASS_CLI" item create login "${login_args[@]}"
    else
        # Custom item via JSON template (pass-cli has no --field flag for login items)
        local tmpfile kvfile
        tmpfile=$(mktemp)
        kvfile=$(mktemp)
        printf '%s\n' "${all_args[@]}" > "$kvfile"
        python3 -c '
import json, sys, os

kv_file = sys.argv[1]
title = sys.argv[2]

fields = []
with open(kv_file) as f:
    for line in f:
        line = line.strip()
        if "=" not in line:
            continue
        key, val = line.split("=", 1)
        fields.append({"field_name": key, "field_type": "hidden", "value": val})

template = {
    "title": title,
    "note": "",
    "sections": [{"section_name": "Details", "fields": fields}]
}
json.dump(template, sys.stdout, indent=2)
' "$kvfile" "$item" > "$tmpfile"
        rm -f "$kvfile"
        "$PASS_CLI" item create custom --vault-name "$vault" --from-template "$tmpfile"
        rm -f "$tmpfile"
    fi
}

_pp_resolve_item_ids() {
    local vault="$1"
    local item="$2"
    "$PASS_CLI" item list "$vault" --output json 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
for i in d['items']:
    if i['title'] == '$item':
        print(i['share_id'] + ' ' + i['id'])
        exit(0)
exit(1)
" 2>/dev/null
}

_pp_delete_item() {
    local vault="$1"
    local item="$2"
    local ids
    ids=$(_pp_resolve_item_ids "$vault" "$item") || { log_error "Item '$item' not found in vault '$vault'"; return 1; }
    local share_id="${ids%% *}"
    local item_id="${ids#* }"
    # Use --key=value syntax to handle IDs starting with '-'
    "$PASS_CLI" item delete "--share-id=${share_id}" "--item-id=${item_id}"
}

_pp_create_vault() {
    local vault="$1"
    if ! _pp_vault_exists "$vault"; then
        "$PASS_CLI" vault create --name "$vault"
    fi
}

_pp_list_items() {
    local vault="${1:-}"
    if [[ -n "$vault" ]]; then
        "$PASS_CLI" item list "$vault"
    else
        "$PASS_CLI" item list
    fi
}

_pp_ssh_load() {
    "$PASS_CLI" ssh-agent load --vault-name "$(resolve_vault ssh)"
}

# ─── Unified Interface ─────────────────────────────────────────────────────────

# Parse a secret reference: "vault/item/field" or "vault/item"
_parse_ref() {
    local ref="$1"
    local vault item field
    # Format: vault/item[/field]
    vault="${ref%%/*}"
    local rest="${ref#*/}"
    if [[ "$rest" == *"/"* ]]; then
        item="${rest%%/*}"
        field="${rest#*/}"
    else
        item="$rest"
        field=""
    fi
    echo "$vault|$item|$field"
}

get_secret() {
    local ref="$1"
    local field="${2:-}"
    local parsed vault item ref_field
    parsed="$(_parse_ref "$ref")"
    IFS='|' read -r vault item ref_field <<< "$parsed"
    if [[ -n "$field" ]]; then
        ref_field="$field"
    fi
    vault="$(resolve_vault "$vault")"
    if [[ -n "$ref_field" ]]; then
        _pp_get_field "$vault" "$item" "$ref_field"
    else
        "$PASS_CLI" item view --vault-name "$vault" --item-title "$item"
    fi
}

copy_secret() {
    local ref="$1"
    local field="$2"
    local value
    value=$(get_secret "$ref" "$field") || die "Failed to get $ref/$field"
    if command -v xclip &>/dev/null; then
        echo -n "$value" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        echo -n "$value" | xsel --clipboard --input
    elif command -v wl-copy &>/dev/null; then
        echo -n "$value" | wl-copy
    else
        die "No clipboard tool found (install xclip, xsel, or wl-clipboard)"
    fi
    log_success "Copied to clipboard - clearing in ${CLIPBOARD_TIMEOUT}s..."
    (sleep "$CLIPBOARD_TIMEOUT" && \
     (echo -n "" | xclip -selection clipboard 2>/dev/null || \
      echo -n "" | xsel --clipboard --input 2>/dev/null || \
      wl-copy --clear 2>/dev/null)) & disown
}

inject_template() {
    local template="$1"
    local output="$2"
    [[ -f "$template" ]] || die "Template not found: $template"
    local tmp
    tmp=$(mktemp)
    cp "$template" "$tmp"
    local replacements=0
    # Find all unique {{ secret:vault/item }} and {{ secret:vault/item/field }} patterns
    local placeholders
    placeholders=$(grep -oP '\{\{\s*secret:[^}]+\}\}' "$template" 2>/dev/null | sort -u) || true
    while IFS= read -r placeholder; do
        [[ -z "$placeholder" ]] && continue
        # Strip {{ and }} and whitespace
        local inner="${placeholder#\{\{}"
        inner="${inner%\}\}}"
        inner="${inner# }"
        inner="${inner% }"
        inner="${inner#secret:}"
        inner="${inner# }"
        local vault item field
        local count
        count=$(echo "$inner" | tr -cd '/' | wc -c)
        if [[ "$count" -ge 2 ]]; then
            # vault/item/field format
            vault="${inner%%/*}"
            local rest="${inner#*/}"
            item="${rest%%/*}"
            field="${rest#*/}"
        else
            # vault/item format — field defaults to password
            vault="${inner%%/*}"
            item="${inner#*/}"
            field="password"
        fi
        local value
        value=$(get_secret "${vault}/${item}" "$field" 2>/dev/null) || { log_warn "Secret not found: ${vault}/${item}/${field}"; continue; }
        local escaped_placeholder escaped_value
        escaped_placeholder=$(printf '%s\n' "$placeholder" | sed 's/[&/\]/\\&/g')
        escaped_value=$(printf '%s\n' "$value" | sed 's/[&/\]/\\&/g')
        sed -i "s|${escaped_placeholder}|${escaped_value}|g" "$tmp"
        # Also try alternate format (with/without explicit field for password)
        if [[ "$field" == "password" ]]; then
            local alt="{{ secret:${vault}/${item} }}"
            local alt_escaped
            alt_escaped=$(printf '%s\n' "$alt" | sed 's/[&/\]/\\&/g')
            sed -i "s|${alt_escaped}|${escaped_value}|g" "$tmp"
        fi
        ((replacements++)) || true
    done <<< "$placeholders"
    local output_dir
    output_dir=$(dirname "$output")
    mkdir -p "$output_dir"
    mv "$tmp" "$output"
    chmod 600 "$output"
    log_success "Injected $replacements secrets into $output"
}

env_secrets() {
    local vault="${1:-}"
    local vault_resolved
    if [[ -n "$vault" ]]; then
        vault_resolved="$(resolve_vault "$vault")"
    fi
    local items_json
    if [[ -n "$vault_resolved" ]]; then
        items_json=$("$PASS_CLI" item list "$vault_resolved" --output json 2>/dev/null) || return 1
    else
        items_json=$("$PASS_CLI" item list --output json 2>/dev/null) || return 1
    fi
    echo "# Run: eval \$(secretmgr env${vault:+ $vault})"
    echo "# Secret environment variables"
    if command -v jq &>/dev/null && echo "$items_json" | jq empty 2>/dev/null; then
        echo "$items_json" | jq -r '.[] | .shareId as \$share | .itemName as \$name | .lastContentFields // {} | to_entries[] | select(.key != "note") | "\(\$share)/\(\$name)/\(.key)=\(.value)"' 2>/dev/null | while IFS='=' read -r path value; do
            local env_name
            env_name=$(echo "$path" | tr '[:lower:]' '[:upper:]' | tr '/-' '__')
            echo "export ${env_name}='${value}'"
        done
    else
        # Fallback: list command gives human-readable output
        "$PASS_CLI" item list "$vault_resolved" 2>/dev/null | while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*$ ]] && continue
            log_info "$line"
        done
        log_warn "Install jq for JSON env export; listing items instead"
    fi
}

# ─── Commands ───────────────────────────────────────────────────────────────────

cmd_init() {
    _pp_check 2>/dev/null || {
        log_info "Installing Proton Pass CLI..."
        if command -v yay &>/dev/null; then
            yay -S --noconfirm proton-pass-cli-bin 2>/dev/null || \
                curl -fsSL https://proton.me/download/pass-cli/install.sh | bash
        else
            curl -fsSL https://proton.me/download/pass-cli/install.sh | bash
        fi
        log_success "pass-cli installed"
    }

    if ! command -v proton-pass &>/dev/null && ! flatpak list 2>/dev/null | grep -qi proton-pass; then
        log_info "Installing Proton Pass GUI..."
        if command -v yay &>/dev/null; then
            yay -S --noconfirm proton-pass-bin
            log_success "proton-pass GUI installed"
        else
            log_warn "Install proton-pass GUI manually from https://proton.me/pass/download/linux"
        fi
    else
        log_info "Proton Pass GUI already installed"
    fi

    # Install shell completions
    local shell="${SHELL##*/}"
    case "$shell" in
        bash)
            mkdir -p ~/.local/share/bash-completion/completions
            "$PASS_CLI" completions bash > ~/.local/share/bash-completion/completions/pass-cli 2>/dev/null || true
            ;;
        zsh)
            mkdir -p ~/.zfunc
            "$PASS_CLI" completions zsh > ~/.zfunc/_pass-cli 2>/dev/null || true
            ;;
        fish)
            mkdir -p ~/.config/fish/completions
            "$PASS_CLI" completions fish > ~/.config/fish/completions/pass-cli.fish 2>/dev/null || true
            ;;
    esac

    _pp_logged_in || {
        log_info "Proton Pass login required — opening browser..."
        "$PASS_CLI" login
        log_success "Logged in to Proton Pass"
    }

    # Create vaults
    local vaults=("API" "NAS" "SSH" "GPG" "VPN" "Servers")
    for vault in "${vaults[@]}"; do
        if _pp_vault_exists "$vault"; then
            log_info "Vault '$vault' already exists"
        else
            "$PASS_CLI" vault create --name "$vault"
            log_success "Created vault: $vault"
        fi
    done

    # Set default vault
    "$PASS_CLI" settings set default-vault "Personal" 2>/dev/null || true

    echo ""
    log_success "Proton Pass initialized!"
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo -e "  1. Add secrets via 'secretmgr add' or the Proton Pass GUI"
    echo -e "  2. Run 'secretmgr bootstrap' to deploy secrets to this machine"
    echo -e "  3. Required Proton Pass items:"
    echo -e "     ${CYAN}API/OpenCode${NC}       — custom item with hidden field: api_key"
    echo -e "     ${CYAN}API/OpenViking${NC}     — custom item with hidden field: api_key"
    echo -e "     ${CYAN}NAS/rsync${NC}          — login item with password"
    echo -e "     ${CYAN}SSH/id_ed25519${NC}     — ssh-key item (use: pass-cli item create ssh-key import --from-private-key ~/.ssh/id_ed25519 --vault-name SSH --title id_ed25519)"
    echo -e "     ${CYAN}GPG/signing-key${NC}    — note item: key_id=LONGID"
    echo -e "     ${CYAN}GPG/private-key${NC}    — note item: base64-encoded armored GPG private key"
    echo ""
}

cmd_add() {
    _pp_check
    local ref="${1:-}"
    local kv_pairs=("${@:2}")
    [[ -z "$ref" ]] && die "Usage: secretmgr add <vault/item> KEY=VALUE ..."
    [[ ${#kv_pairs[@]} -eq 0 ]] && die "Usage: secretmgr add <vault/item> KEY=VALUE ..."
    local parsed vault item _
    parsed="$(_parse_ref "$ref")"
    IFS='|' read -r vault item _ <<< "$parsed"
    vault="$(resolve_vault "$vault")"
    _pp_create_item "$vault" "$item" "${kv_pairs[@]}"
    log_success "Stored: $ref"
}

cmd_get() {
    _pp_check
    local ref="${1:-}"
    local field="${2:-}"
    [[ -z "$ref" ]] && die "Usage: secretmgr get <vault/item> [FIELD]"
    get_secret "$ref" "$field"
}

cmd_copy() {
    _pp_check
    local ref="${1:-}"
    local field="${2:-}"
    [[ -z "$ref" ]] && die "Usage: secretmgr copy <vault/item> <FIELD>"
    [[ -z "$field" ]] && die "Usage: secretmgr copy <vault/item> <FIELD>"
    copy_secret "$ref" "$field"
}

cmd_list() {
    _pp_check
    local vault="${1:-}"
    local vault_resolved
    if [[ -n "$vault" ]]; then
        vault_resolved="$(resolve_vault "$vault")"
    fi
    _pp_list_items "$vault_resolved"
}

cmd_delete() {
    _pp_check
    local ref="${1:-}"
    [[ -z "$ref" ]] && die "Usage: secretmgr delete <vault/item>"
    local parsed vault item _
    parsed="$(_parse_ref "$ref")"
    IFS='|' read -r vault item _ <<< "$parsed"
    vault="$(resolve_vault "$vault")"
    read -rp "Delete '$ref'? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { log_info "Aborted"; return; }
    _pp_delete_item "$vault" "$item"
    log_success "Deleted: $ref"
}

cmd_env() {
    _pp_check
    local vault="${1:-}"
    env_secrets "$vault"
}

cmd_inject() {
    _pp_check
    local template="${1:-}"
    local output="${2:-}"
    [[ -z "$template" ]] && die "Usage: secretmgr inject <template> <output>"
    [[ -z "$output" ]] && die "Usage: secretmgr inject <template> <output>"
    inject_template "$template" "$output"
}

cmd_ssh_add() {
    _pp_check
    log_info "Loading SSH keys from Proton Pass into ssh-agent..."
    # Ensure ssh-agent is available
    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        # Try systemd user service socket
        local sock
        sock=$(systemctl --user show ssh-agent.service -p Listen 2>/dev/null | grep -oP '/run/user/\d+/ssh-agent\.sock' || true)
        if [[ -n "$sock" && -S "$sock" ]]; then
            export SSH_AUTH_SOCK="$sock"
        else
            die "ssh-agent not running. Enable ssh-agent.service or start ssh-agent"
        fi
    fi
    _pp_ssh_load
    log_success "SSH keys loaded into agent"
}

cmd_status() {
    _pp_check
    if _pp_logged_in; then
        log_success "Proton Pass session active"
        "$PASS_CLI" info
    else
        log_error "Not logged in to Proton Pass"
        echo "Run: secretmgr init"
        return 1
    fi
}

cmd_bootstrap() {
    _pp_check || {
        log_info "pass-cli not found, running init..."
        cmd_init
    }

    if ! _pp_logged_in; then
        log_info "Proton Pass login required — opening browser..."
        "$PASS_CLI" login
        log_success "Logged in to Proton Pass"
    fi

    local errors=0

    # ── Create vaults if missing ──
    local vaults=("API" "NAS" "SSH" "GPG" "VPN" "Servers")
    for vault in "${vaults[@]}"; do
        if _pp_vault_exists "$vault"; then
            log_info "Vault '$vault' exists"
        else
            "$PASS_CLI" vault create --name "$vault" 2>/dev/null && log_success "Created vault: $vault" || { log_error "Failed to create vault: $vault"; ((errors++)); }
        fi
    done

    # ── Deploy config files from templates ──
    local templates_found=0
    local tmpl output
    # OpenCode config
    tmpl="$HOME/.config/opencode/opencode.json.tmpl"
    output="$HOME/.config/opencode/opencode.json"
    if [[ -f "$tmpl" ]]; then
        inject_template "$tmpl" "$output" || { log_error "Failed to inject opencode.json"; ((errors++)); }
        ((templates_found++)) || true
    else
        log_info "No template at $tmpl — skipping"
    fi

    # OpenViking config
    tmpl="$HOME/.openviking/openviking-config.json.tmpl"
    output="$HOME/.openviking/openviking-config.json"
    if [[ -f "$tmpl" ]]; then
        inject_template "$tmpl" "$output" || { log_error "Failed to inject openviking-config.json"; ((errors++)); }
        ((templates_found++)) || true
    else
        log_info "No template at $tmpl — skipping"
    fi

    # ── Deploy NAS rsync password ──
    local nas_password_file="$HOME/.config/nas-sync/rsync-password"
    if [[ -f "$nas_password_file" ]]; then
        log_info "NAS rsync password file already exists"
    else
        local nas_pass
        nas_pass=$(get_secret "NAS/rsync" "password" 2>/dev/null) || true
        if [[ -n "$nas_pass" ]]; then
            mkdir -p "$(dirname "$nas_password_file")"
            printf '%s' "$nas_pass" > "$nas_password_file"
            chmod 600 "$nas_password_file"
            log_success "NAS rsync password deployed from Proton Pass"
        else
            log_warn "NAS/rsync password not found in Proton Pass — set it manually"
            echo "  secretmgr add NAS/rsync password=YOUR_PASSWORD"
        fi
    fi

    # ── Deploy SSH key ──
    if [[ -f "$HOME/.ssh/id_ed25519" ]]; then
        log_info "SSH key already exists at ~/.ssh/id_ed25519"
    else
        # Try to retrieve SSH private key from Proton Pass
        local ssh_key_content
        ssh_key_content=$(get_secret "SSH/id_ed25519" "private_key" 2>/dev/null) || true
        if [[ -n "$ssh_key_content" ]]; then
            mkdir -p "$HOME/.ssh"
            chmod 700 "$HOME/.ssh"
            printf '%s' "$ssh_key_content" > "$HOME/.ssh/id_ed25519"
            chmod 600 "$HOME/.ssh/id_ed25519"
            log_success "SSH key deployed from Proton Pass"
        else
            log_warn "SSH/id_ed25519 not found in Proton Pass — import it with:"
            echo "  pass-cli item create ssh-key import --from-private-key ~/.ssh/id_ed25519 --vault-name SSH --title id_ed25519"
        fi
    fi

    # ── Load SSH keys into agent ──
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        cmd_ssh_add 2>/dev/null || log_warn "Failed to load SSH keys into agent"
    else
        log_info "No ssh-agent running — run 'secretmgr ssh-add' after starting agent"
    fi

    # ── Deploy GPG keys ──
    # GPG keys are stored as note items in the GPG vault:
    #   - signing-key: note contains "key_id=LONGID"
    #   - default-key: note contains "key_id=LONGID"
    #   - private-key: note contains base64-encoded armored GPG private key
    local gpg_vault="GPG"
    local gpg_key_imported=false
    for key_item in signing-key default-key; do
        local key_id_raw
        key_id_raw=$("$PASS_CLI" item view --vault-name "$gpg_vault" --item-title "$key_item" 2>/dev/null | sed -n 's/^- Note: //p') || true
        local key_id="${key_id_raw#key_id=}"
        if [[ -n "$key_id" ]]; then
            if gpg --list-secret-keys "$key_id" &>/dev/null; then
                log_info "GPG key $key_id already imported"
            else
                # Retrieve the base64-encoded private key from the private-key item
                local gpg_key_b64
                gpg_key_b64=$("$PASS_CLI" item view --vault-name "$gpg_vault" --item-title "private-key" --field "note" 2>/dev/null) || true
                if [[ -n "$gpg_key_b64" ]]; then
                    local tmpfile
                    tmpfile=$(mktemp)
                    echo "$gpg_key_b64" | base64 -d > "$tmpfile"
                    if gpg --import "$tmpfile" 2>/dev/null; then
                        echo "$key_id:6:" | gpg --import-ownertrust 2>/dev/null || true
                        log_success "GPG key $key_id imported from Proton Pass"
                        gpg_key_imported=true
                    else
                        log_warn "Failed to import GPG key $key_id"
                    fi
                    shred -u "$tmpfile" 2>/dev/null || rm -f "$tmpfile"
                else
                    log_warn "GPG private-key note not found in Proton Pass"
                fi
            fi
            # Only need to import once even if both signing-key and default-key reference same key
            if $gpg_key_imported; then
                break
            fi
        fi
    done

    # ── Summary ──
    echo ""
    echo -e "  ${BOLD}${CYAN}══════════════════════════════════════════${NC}"
    echo -e "  ${BOLD}${CYAN}  Bootstrap Summary${NC}"
    echo -e "  ${BOLD}${CYAN}══════════════════════════════════════════${NC}"
    if [[ $errors -eq 0 ]]; then
        echo -e "  ${GREEN}✓ All secrets bootstrapped successfully${NC}"
    else
        echo -e "  ${RED}✗ $errors error(s) occurred${NC}"
    fi
    echo ""
    echo -e "  Templates injected: ${templates_found}"
    echo -e "  Run 'secretmgr status' to verify your Proton Pass session"
}

cmd_help() {
    cat <<EOF

 ${CYAN}secretmgr${NC} v${VERSION} — Proton Pass CLI wrapper

 ${YELLOW}SETUP:${NC}
   secretmgr init                          Install pass-cli, login, create vaults
   secretmgr status                        Check Proton Pass session status

 ${YELLOW}MANAGING SECRETS:${NC}
   secretmgr add <vault/item> KEY=val...   Add/update a secret
   secretmgr get <vault/item> [FIELD]      Get a secret value
   secretmgr copy <vault/item> FIELD       Copy to clipboard (auto-clears 45s)
   secretmgr list [vault]                  List all secrets
   secretmgr delete <vault/item>            Delete a secret

 ${YELLOW}CONFIG FILE INTEGRATION:${NC}
   secretmgr inject <template> <output>    Replace {{ secret:vault/item/field }} placeholders

 ${YELLOW}AUTOMATION:${NC}
   secretmgr env [vault]                   Print shell exports (eval-able)
   secretmgr bootstrap                     Deploy all secrets to this machine

 ${YELLOW}SSH AGENT:${NC}
   secretmgr ssh-add                       Load SSH keys from Proton Pass into agent

 ${YELLOW}EXAMPLES:${NC}
   secretmgr add NAS/rsync password=mypass
   secretmgr add API/OpenCode api_key=sk-xxx
   secretmgr add API/OpenViking account=me user=nate password=xxx api_key=xxx
   secretmgr get NAS/rsync password
   secretmgr copy API/OpenCode api_key
   secretmgr inject opencode.json.tmpl opencode.json

   # Load secrets as env vars:
   eval \$(secretmgr env API)

 ${YELLOW}CONFIG FILE TEMPLATE SYNTAX:${NC}
   In any config file, use:  {{ secret:vault/item/field }}
   Example:  "apiKey": "{{ secret:API/OpenCode/api_key }}"

 ${YELLOW}VAULT ALIASES (from config.toml):${NC}
EOF
    for key in "${!VAULT_MAP[@]}"; do
        echo -e "   $key → ${VAULT_MAP[$key]}"
    done
    echo ""
}

# ─── Main Dispatcher ────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    load_config

    case "$cmd" in
        init)           cmd_init "$@" ;;
        add|set)        cmd_add "$@" ;;
        get|show)       cmd_get "$@" ;;
        copy|cp)         cmd_copy "$@" ;;
        list|ls)         cmd_list "$@" ;;
        delete|rm)       cmd_delete "$@" ;;
        env)             cmd_env "$@" ;;
        inject)         cmd_inject "$@" ;;
        ssh-add)        cmd_ssh_add "$@" ;;
        status)          cmd_status "$@" ;;
        bootstrap)      cmd_bootstrap "$@" ;;
        help|--help|-h) cmd_help ;;
        *)              log_error "Unknown command: $cmd"; cmd_help; exit 1 ;;
    esac
}

main "$@"