#!/usr/bin/env bash
#
# hot-procs — detect high-CPU processes and print suggested kill commands
#             Does NOT kill anything. Copy-paste commands to act.
#
# Usage: hot-procs [--threshold N] [--time N]
#   --threshold N   CPU% threshold (default: 80)
#   --time N        Sustained CPU time threshold in seconds (default: 300 = 5min)
#

set -euo pipefail

CPU_THRESHOLD=80
TIME_THRESHOLD=300  # seconds
SELF=$$

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --threshold) CPU_THRESHOLD="$2"; shift 2 ;;
    --time)      TIME_THRESHOLD="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Convert ps TIME field (e.g. "30:54", "1:02:03") to seconds
time_to_seconds() {
  local t="$1"
  local -i s=0
  IFS=: read -ra parts <<< "$t"
  case "${#parts[@]}" in
    2) s=$(( 10#${parts[0]} * 60 + 10#${parts[1]} )) ;;
    3) s=$(( 10#${parts[0]} * 3600 + 10#${parts[1]} * 60 + 10#${parts[2]} )) ;;
  esac
  echo "$s"
}

# Collect process data: pid cpu_pct time command
# Skip kernel threads ([...]), PID 0, and self
mapfile -t PROC_LINES < <(
  ps ax -o pid=,pcpu=,time=,comm= --sort=-pcpu 2>/dev/null \
  | awk -v self="$SELF" '
    {
      pid=$1; cpu=$2; tim=$3; cmd=$4
      if (pid == self) next
      if (cmd ~ /^\[/) next
      if (pid == 0) next
      print pid, cpu, tim, cmd
    }
  '
)

# Section 1: High CPU% (above threshold right now)
echo ""
echo "=== High CPU processes (>${CPU_THRESHOLD}%) ==="

hot_pids=()
found=0
printf "  %-8s %-6s %-12s %s\n" "PID" "CPU%" "TIME" "COMMAND"
for line in "${PROC_LINES[@]}"; do
  read -r pid cpu tim cmd <<< "$line"
  # Use awk for float comparison
  is_hot=$(awk -v c="$cpu" -v t="$CPU_THRESHOLD" 'BEGIN { print (c+0 >= t+0) ? "1" : "0" }')
  if [[ "$is_hot" == "1" ]]; then
    printf "  %-8s %-6s %-12s %s\n" "$pid" "$cpu" "$tim" "$cmd"
    hot_pids+=("$pid:$cmd")
    found=1
  fi
done

if [[ $found -eq 0 ]]; then
  echo "  None found."
else
  echo ""
  echo "  Suggested kill commands:"
  for entry in "${hot_pids[@]}"; do
    IFS=: read -r pid cmd <<< "$entry"
    echo "    kill $pid  # $cmd"
  done
fi

# Section 2: Sustained CPU hogs (above threshold AND above time threshold)
echo ""
echo "=== Sustained CPU hogs (>${CPU_THRESHOLD}% CPU and >${TIME_THRESHOLD}s CPU time) ==="

sustained_pids=()
found=0
printf "  %-8s %-6s %-12s %s\n" "PID" "CPU%" "TIME" "COMMAND"
for line in "${PROC_LINES[@]}"; do
  read -r pid cpu tim cmd <<< "$line"
  is_hot=$(awk -v c="$cpu" -v t="$CPU_THRESHOLD" 'BEGIN { print (c+0 >= t+0) ? "1" : "0" }')
  if [[ "$is_hot" == "1" ]]; then
    secs=$(time_to_seconds "$tim")
    if (( secs >= TIME_THRESHOLD )); then
      printf "  %-8s %-6s %-12s %s\n" "$pid" "$cpu" "$tim" "$cmd"
      sustained_pids+=("$pid:$cmd")
      found=1
    fi
  fi
done

if [[ $found -eq 0 ]]; then
  echo "  None found."
else
  echo ""
  echo "  Suggested kill commands:"
  for entry in "${sustained_pids[@]}"; do
    IFS=: read -r pid cmd <<< "$entry"
    echo "    kill $pid  # $cmd"
  done
fi

echo ""
echo "NOTE: No processes were killed. Copy-paste commands above to act."
echo ""

exit 0
