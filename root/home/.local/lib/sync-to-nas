#!/usr/bin/env bash
# Bidirectional sync script for syncing directories with NAS
# Usage: sync-to-nas <local_dir> <nas_subdir>

set -euo pipefail

if [ $# -ne 2 ]; then
    echo "Usage: $0 <local_dir> <nas_subdir>"
    echo "Example: $0 ~/Documents documents"
    exit 1
fi

LOCAL_DIR="$1"
NAS_SUBDIR="$2"
NAS_HOST="tnas"
NAS_PORT="873"
USERNAME="funkybooboo"
NAS_RSYNC_BASE="rsync://$USERNAME@$NAS_HOST:$NAS_PORT/public/funkybooboo"

# Password file location (will be created separately)
PASSWORD_FILE="$HOME/.config/nas-sync/rsync-password"

# Per-subdir lock so concurrent invocations (manual run + systemd timer, or two
# timer fires) don't race: rsync --delete treats another session's temp file
# (.name.XXXXXX) as a stale file not in the source list and deletes it mid-
# transfer, causing "stat temp file failed: No such file" / rename ENOENT errors.
# Different subdirs are independent (--delete stays within its own subtree) so
# they may still run in parallel; only same-subdir runs serialize.
LOCK_DIR="${XDG_RUNTIME_DIR:-/tmp}/nas-sync"
mkdir -p "$LOCK_DIR"
LOCK_FILE="$LOCK_DIR/${NAS_SUBDIR//\//_}.lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "A sync of NAS:$NAS_SUBDIR is already in progress. Skipping this run."
    exit 0
fi

# Check if NAS is reachable
if ! "$HOME/.local/lib/check-nas-connection"; then
    echo "NAS not reachable. Skipping sync."
    exit 0
fi

# Check if password file exists; try secretmgr as fallback
if [ ! -f "$PASSWORD_FILE" ]; then
    if command -v secretmgr &>/dev/null && secretmgr status &>/dev/null; then
        NAS_PASS=$(secretmgr get NAS/rsync password 2>/dev/null) || true
        if [ -n "$NAS_PASS" ]; then
            printf '%s' "$NAS_PASS" > "$PASSWORD_FILE"
            chmod 600 "$PASSWORD_FILE"
        fi
    fi
    # Re-check after fallback attempt
    if [ ! -f "$PASSWORD_FILE" ]; then
        echo "Error: Password file not found at $PASSWORD_FILE"
        echo "Create it with: secretmgr get NAS/rsync password > $PASSWORD_FILE && chmod 600 $PASSWORD_FILE"
        echo "Or manually: printf 'your_password' > $PASSWORD_FILE && chmod 600 $PASSWORD_FILE"
        exit 1
    fi
fi

# Ensure local directory exists
mkdir -p "$LOCAL_DIR"

# Rsync options:
# -a: archive mode (preserve permissions, times, etc.)
# -v: verbose
# -z: compress during transfer
# -u: skip files that are newer on receiver
# --delete: delete files that don't exist on sender
# --progress: show progress
# --password-file: use password from file

RSYNC_OPTS="-avzu --delete --progress --password-file=$PASSWORD_FILE"
REMOTE="$NAS_RSYNC_BASE/$NAS_SUBDIR/"

echo "=== Syncing $LOCAL_DIR with NAS:$NAS_SUBDIR ==="

# First: Sync local → NAS (upload changes)
echo "--- Uploading local changes to NAS ---"
rsync $RSYNC_OPTS "$LOCAL_DIR/" "$REMOTE"

# Second: Sync NAS → local (download changes)
echo "--- Downloading NAS changes to local ---"
rsync $RSYNC_OPTS "$REMOTE" "$LOCAL_DIR/"

echo "=== Sync complete ==="