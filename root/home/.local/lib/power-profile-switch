#!/bin/bash
# Automatically switch power profiles based on AC adapter state
# Includes retry logic to handle power-profiles-daemon startup timing

MAX_RETRIES=10
RETRY_DELAY=1

AC_PATH=$(find /sys/class/power_supply -name 'AC*' -o -name 'ADP*' | head -1)

if [ -z "$AC_PATH" ]; then
    logger "power-profile-switch: Could not find AC adapter path"
    exit 1
fi

AC_STATE=$(cat "$AC_PATH/online" 2>/dev/null)
TARGET="power-saver"
[ "$AC_STATE" = "1" ] && TARGET="performance"

for i in $(seq 1 $MAX_RETRIES); do
    if powerprofilesctl set "$TARGET" 2>/dev/null; then
        logger "power-profile-switch: Switched to $TARGET (AC_STATE=$AC_STATE, attempt=$i)"
        exit 0
    fi
    sleep $RETRY_DELAY
done

logger "power-profile-switch: Failed to set $TARGET after $MAX_RETRIES attempts"
exit 1
