[Match]
Type=wlan

[Link]
RequiredForOnline=routable

[Network]
DHCP=yes
MulticastDNS=yes

# Explicit route metric: Ethernet (100) preferred over Wi-Fi (600) preferred
# over WWAN (700). systemd-networkd does not set per-interface-type default
# route metrics. Values from NetworkManager (nm_device_get_route_metric_default).
[DHCPv4]
RouteMetric=600

[IPv6AcceptRA]
RouteMetric=600
