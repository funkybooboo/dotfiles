#!/usr/bin/env bash
# Pre-commit hook: prevent secrets from being committed
set -euo pipefail

RED='\033[0;31m'
NC='\033[0m'

found_secrets=0

# Patterns that indicate leaked secrets
SECRET_PATTERNS='(AKIA[0-9A-Z]{16}|AIzaSy[0-9A-Za-z_-]{33}|AQ\.[0-9A-Za-z_-]{40,}|sk-[0-9a-zA-Z]{48}|sk_live_[0-9a-zA-Z]{24,}|ghp_[0-9a-zA-Z]{36}|gho_[0-9a-zA-Z]{36}|github_pat_[0-9a-zA-Z_]{82}|-----BEGIN[[:space:]]+RSA[[:space:]]+PRIVATE[[:space:]]+KEY|-----BEGIN[[:space:]]+OPENSSH[[:space:]]+PRIVATE[[:space:]]+KEY|-----BEGIN[[:space:]]+EC[[:space:]]+PRIVATE[[:space:]]+KEY|-----BEGIN[[:space:]]+DSA[[:space:]]+PRIVATE[[:space:]]+KEY)'

# Scan staged diffs for secret patterns
if git diff --cached 2>/dev/null | grep -qiE "$SECRET_PATTERNS"; then
    echo -e "${RED}SECRET DETECTED in staged changes!${NC}"
    git diff --cached 2>/dev/null | grep -iE "$SECRET_PATTERNS" || true
    found_secrets=1
fi

# Check for files that should never be committed
while IFS= read -r file; do
    case "$file" in
        *ov.conf*)
            if [[ "$file" != *".tmpl"* ]]; then
                echo -e "${RED}BLOCKED${NC}: $file is a secret config (not a .tmpl). Use secretmgr templates instead."
                found_secrets=1
            fi
            ;;
        *rsync-password*)
            echo -e "${RED}BLOCKED${NC}: $file is a credentials file. Add to .gitignore."
            found_secrets=1
            ;;
        *.pem|*.key|*.p12|*.pfx)
            echo -e "${RED}BLOCKED${NC}: $file is a private key/certificate file."
            found_secrets=1
            ;;
    esac
    bn=$(basename "$file")
    case "$bn" in
        id_ed25519|id_rsa|id_ecdsa)
            echo -e "${RED}BLOCKED${NC}: $file is an SSH private key."
            found_secrets=1
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

if [[ $found_secrets -eq 1 ]]; then
    echo ""
    echo -e "${RED}Commit rejected: secrets detected.${NC}"
    echo "Move secrets to secretmgr templates ({{ secret:... }}) or add to .gitignore."
    exit 1
fi

exit 0